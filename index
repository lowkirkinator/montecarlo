    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Fira+Mono:wght@400;500&display=swap');

        :root {
            /* Keep all original color accents but adjust background and main text */
            --bg-body: #0f1117; /* Dark background outside .page */
            --page-bg: #fff; /* New white page background */
            --text-dark: #000; /* New dark text color for content */
            --border: #ddd; /* Lighter border for light theme */
            --accent1: #6c8ef0; /* Blå */
            --accent2: #e07b54; /* Orange */
            --accent3: #5ec4a1; /* Grön */
            --accent4: #c97fe8; /* Lila */
            --accent5: #f0c96c; /* Gul */
            --muted-light: #666; /* New dark muted text color */
            --tag-bg-light: #f4f4f4; /* Lighter background for tags in light theme */
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-body); /* Body background outside the main content area */
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            line-height: 1.6;
            padding: 40px 20px;
        }

        .page {
            max-width: 1100px;
            margin: 0 auto;
            background: var(--page-bg); /* Use the new white background */
            border-radius: 12px;
            padding: 60px 80px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            color: var(--text-dark); /* Set default dark text for the white page */
        }

        /* HEADER */
        .header {
            text-align: center;
            margin-bottom: 56px;
            padding: 48px 0 40px;
            border-bottom: 2px solid #333; /* Darker border in light theme */
            position: relative;
        }
        .header::before {
            content: '';
            position: absolute;
            top: 0; left: 50%; transform: translateX(-50%);
            width: 60px; height: 3px;
            background: linear-gradient(90deg, var(--accent1), var(--accent4));
            border-radius: 2px;
        }
        .header h1 {
            font-size: 32px;
            font-weight: 700;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, #000, #333); /* Dark titles on white background */
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
        }
        .header .sub {
            color: var(--muted-light); /* Darker muted text color */
            font-size: 13px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        /* SECTION LABEL */
        .section-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #333; /* Darker title in light theme */
            margin: 60px 0 24px;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #999; /* Darker border in light theme */
        }

        /* GRID LAYOUT */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
        .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 20px; }
        .col-span-2 { grid-column: span 2; }
        .col-span-3 { grid-column: span 3; }

        /* CARD */
        .card {
            background: var(--tag-bg-light); /* Lighter background for cards on a white page */
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 24px;
            position: relative;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }
        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            border-radius: 12px 12px 0 0;
        }
        .card.blue::before { background: var(--accent1); }
        .card.orange::before { background: var(--accent2); }
        .card.green::before { background: var(--accent3); }
        .card.purple::before { background: var(--accent4); }
        .card.yellow::before { background: var(--accent5); }

        .card h2 {
            font-size: 15px;
            font-weight: 600;
            letter-spacing: 0.3px;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 7px;
            color: #000; /* Dark title for card */
        }
        .card h2 .dot {
            width: 7px; height: 7px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .card.blue h2 .dot { background: var(--accent1); }
        .card.orange h2 .dot { background: var(--accent2); }
        .card.green h2 .dot { background: var(--accent3); }
        .card.purple h2 .dot { background: var(--accent4); }
        .card.yellow h2 .dot { background: var(--accent5); }

        .question-block {
            margin-bottom: 35px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
        }
        .q-header {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 8px;
            color: #000; /* Dark question title */
        }
        .tags {
            font-family: "Fira Mono", monospace;
            font-size: 12px;
            color: var(--muted-light); /* Dark muted text */
            margin-bottom: 12px;
        }
        .tag {
            display: inline-block;
            background: #e8e8e8;
            padding: 3px 8px;
            border-radius: 4px;
            margin-right: 6px;
            border: 1px solid #ccc;
            font-size: 11px;
            color: #555;
        }
        .tag.latt { border-left: 4px solid var(--accent3); }
        .tag.medel { border-left: 4px solid var(--accent5); }
        .tag.svar { border-left: 4px solid var(--accent2); }

        p {
            margin: 8px 0 15px 0;
            text-align: justify;
            color: var(--text-dark); /* Dark text for paragraphs */
        }
        ol, ul {
            margin-top: 8px;
            padding-left: 25px;
            color: var(--text-dark); /* Dark text for lists */
        }
        li {
            margin-bottom: 8px;
        }
        .math {
            font-family: "Fira Mono", monospace;
            background: #eee; /* Lighter math background in light theme */
            padding: 10px;
            border-radius: 6px;
            margin: 10px 0;
            display: block;
            overflow-x: auto;
            color: var(--text-dark); /* Dark text for math */
        }

        /* HIGHLIGHT BOX */
        .highlight {
            background: #eee; /* Lighter highlight background in light theme */
            border-left: 3px solid var(--accent1);
            border-radius: 0 8px 8px 0;
            padding: 12px 16px;
            margin: 10px 0;
            font-size: 13px;
            color: var(--text-dark); /* Dark text for highlights */
        }
        .highlight strong { color: #000; font-weight: 600; }
        .highlight.orange { border-left-color: var(--accent2); }
        .highlight.green { border-left-color: var(--accent3); }
        .highlight.purple { border-left-color: var(--accent4); }

        /* ACRONYM BLOCK */
        .acronym { display: flex; flex-direction: column; gap: 4px; margin: 10px 0; }
        .acronym-row { display: flex; align-items: baseline; gap: 10px; font-size: 13px; color: var(--text-dark); }
        .acronym-letter {
            font-family: 'Fira Mono', monospace;
            font-size: 14px;
            font-weight: 700;
            width: 18px;
            flex-shrink: 0;
            color: var(--accent1);
        }
        .acronym-row.orange .acronym-letter { color: var(--accent2); }
        .acronym-row.green .acronym-letter { color: var(--accent3); }
        .acronym-row.purple .acronym-letter { color: var(--accent4); }
        .acronym-row.yellow .acronym-letter { color: var(--accent5); }
        .acronym-row span { color: var(--text-dark); }

        /* QUOTE */
        .quote {
            font-style: italic;
            color: var(--muted-light); /* Darker muted text for quote */
            border-left: 2px solid var(--border);
            padding-left: 12px;
            margin: 10px 0;
            font-size: 12.5px;
            line-height: 1.7;
        }

        /* COMPARISON */
        .compare { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 10px; }
        .compare-col { background: #eee; border-radius: 8px; padding: 14px; }
        .compare-col .c-title { font-weight: 700; font-size: 12px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
        .compare-col.blue .c-title { color: var(--accent1); }
        .compare-col.orange .c-title { color: var(--accent2); }
        .compare-col ul { list-style: none; padding: 0; }
        .compare-col ul li { font-size: 12.5px; color: var(--text-dark); padding: 3px 0; border-bottom: 1px solid var(--border); }
        .compare-col ul li:last-child { border-bottom: none; }
        .compare-col ul li::before { content: '› '; color: var(--accent3); }

        /* EVM */
        .evm-row { display: flex; gap: 8px; margin-top: 8px; }
        .evm-box { flex: 1; background: #eee; border-radius: 8px; padding: 10px 12px; border: 1px solid var(--border); }
        .evm-box .evm-label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--muted-light); margin-bottom: 4px; }
        .evm-box .evm-code { font-family: 'Fira Mono', monospace; font-size: 13px; font-weight: 700; margin-bottom: 2px; }
        .evm-box .evm-full { font-size: 11px; color: var(--text-dark); }
        .evm-box.blue .evm-code { color: var(--accent1); }
        .evm-box.green .evm-code { color: var(--accent3); }
        .evm-box.orange .evm-code { color: var(--accent2); }
        .evm-box.purple .evm-code { color: var(--accent4); }

        /* STEP BADGE */
        .num-badge {
            display: inline-flex;
            width: 22px; height: 22px;
            background: var(--accent1);
            border-radius: 50%;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            color: #fff; /* Always white number */
            margin-right: 6px;
            flex-shrink: 0;
        }
        .num-badge.orange { background: var(--accent2); }
        .num-badge.green { background: var(--accent3); }
        .num-badge.purple { background: var(--accent4); }

        .step-row {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 13px;
        }
        .step-row:last-child { border-bottom: none; }
        .step-row .step-content { flex: 1; color: var(--text-dark); }
        .step-row .step-content strong { display: block; color: #000; font-size: 13px; margin-bottom: 2px; font-weight: 600; }
        .step-row .step-content span { color: var(--text-dark); font-size: 12px; }

        /* MULTIPROJEKT Multiprojektverksamhet & PMO */
        .grid-3 ul li { color: var(--text-dark); }
        .grid-3 div div { color: var(--accent5); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; margin-bottom: 6px; font-size: 11px; }

        /* FOOTER */
        .footer { text-align: center; margin-top: 60px; padding-top: 24px; border-top: 1px solid var(--border); color: var(--muted-light); font-size: 11px; }

        @media print {
            body { background: white; padding: 0; }
            .page { box-shadow: none; padding: 0; max-width: 100%; border-radius: 0; }
            .page { page-break-after: always; }
            .question-block { page-break-inside: avoid; }
        }
