<!DOCTYPE html>
<html lang="sv">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Computational Finance — Övningskompendium</title>
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0e0c;
    --bg2: #161411;
    --bg3: #1e1b17;
    --border: #2e2a24;
    --gold: #c8a96e;
    --gold-dim: #8a6f42;
    --cream: #e8e0d0;
    --cream-dim: #a09880;
    --red: #c05a3a;
    --blue: #5b8fa8;
    --green: #6a9e6a;
    --text: #d4ccc0;
    --text-dim: #7a7060;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'EB Garamond', serif;
    font-size: 17px;
    line-height: 1.75;
    min-height: 100vh;
  }

  /* ── HEADER ── */
  header {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    padding: 4rem 3rem 3rem;
    position: relative;
    overflow: hidden;
  }
  header::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,169,110,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .header-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  header h1 {
    font-family: 'Libre Baskerville', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  header h1 span { color: var(--gold); }
  header .subtitle {
    color: var(--cream-dim);
    font-size: 1.05rem;
    font-style: italic;
    margin-bottom: 2rem;
  }
  .header-meta {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .meta-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.3rem 0.8rem;
    border-radius: 2px;
  }

  /* ── NAV ── */
  nav {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    padding: 0 3rem;
    display: flex;
    gap: 0;
    overflow-x: auto;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  nav a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-decoration: none;
    padding: 1rem 1.2rem;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
  }
  nav a:hover { color: var(--gold); border-color: var(--gold); }

  /* ── LAYOUT ── */
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }

  /* ── CHAPTER HEADING ── */
  .chapter {
    margin-top: 5rem;
    margin-bottom: 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .chapter:first-child { border-top: none; margin-top: 2rem; }
  .chapter-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .chapter h2 {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: 0.4rem;
  }
  .chapter-desc {
    color: var(--text-dim);
    font-style: italic;
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  /* ── SECTION ── */
  .section {
    margin-top: 3rem;
  }
  .section h3 {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.2rem;
    color: var(--gold);
    margin-bottom: 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
    font-weight: 400;
    font-style: italic;
  }

  /* ── THEORY BOX ── */
  .theory {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold-dim);
    padding: 1rem 1.25rem;
    margin: 1.2rem 0 1.5rem;
    border-radius: 0 2px 2px 0;
  }
  .theory .theory-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .theory p, .theory .formula {
    font-size: 0.95rem;
    color: var(--cream-dim);
    line-height: 1.6;
  }
  .formula {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--cream);
    background: rgba(0,0,0,0.3);
    padding: 0.6rem 1rem;
    margin: 0.6rem 0 0;
    border-radius: 2px;
    display: block;
    overflow-x: auto;
  }

  /* ── QUESTIONS ── */
  .questions { margin-top: 1rem; }

  .q-item {
    display: grid;
    grid-template-columns: 2.2rem 1fr;
    gap: 0 0.8rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(46,42,36,0.5);
    align-items: start;
    transition: background 0.15s;
  }
  .q-item:hover {
    background: rgba(200,169,110,0.02);
  }
  .q-item:last-child { border-bottom: none; }

  .q-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--gold-dim);
    padding-top: 0.15rem;
    text-align: right;
  }
  .q-text {
    color: var(--text);
    font-size: 0.97rem;
    line-height: 1.65;
  }
  .q-text .sub {
    display: block;
    margin-top: 0.4rem;
    padding-left: 1.2rem;
    color: var(--cream-dim);
    font-size: 0.92rem;
    border-left: 2px solid var(--border);
  }

  /* tags */
  .tag {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    margin-left: 0.4rem;
    vertical-align: middle;
    text-transform: uppercase;
  }
  .tag-slide { background: rgba(91,143,168,0.15); color: var(--blue); border: 1px solid rgba(91,143,168,0.3); }
  .tag-ex    { background: rgba(106,158,106,0.15); color: var(--green); border: 1px solid rgba(106,158,106,0.3); }
  .tag-hard  { background: rgba(192,90,58,0.15); color: var(--red); border: 1px solid rgba(192,90,58,0.3); }

  /* ── HARD PROBLEMS ── */
  .hard-section {
    margin-top: 5rem;
    padding: 2rem;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-top: 3px solid var(--red);
  }
  .hard-section h2 {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.5rem;
    color: var(--cream);
    margin-bottom: 0.3rem;
  }
  .hard-problem {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .hard-problem h4 {
    font-family: 'Libre Baskerville', serif;
    color: var(--gold);
    font-size: 1.05rem;
    font-weight: 400;
    font-style: italic;
    margin-bottom: 0.6rem;
  }
  .hard-problem .setup {
    font-size: 0.93rem;
    color: var(--cream-dim);
    margin-bottom: 0.8rem;
    font-style: italic;
  }

  /* ── FOOTER ── */
  footer {
    margin-top: 5rem;
    border-top: 1px solid var(--border);
    padding: 2rem 3rem;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }

  /* ── PRINT ── */
  @media print {
    nav { display: none; }
    .chapter { page-break-before: always; }
    .hard-section { page-break-before: always; }
    body { background: white; color: black; }
    .theory { background: #f5f5f0; border-color: #ccc; }
  }

  /* scroll-reveal animation */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .section { animation: fadeUp 0.4s ease both; }
</style>
